// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Incident {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  context      String   @db.Text
  whatHappened String   @db.Text @map("what_happened")
  rootCause    String   @db.Text @map("root_cause")
  impact       String   @db.Text
  fix          String   @db.Text
  lessons      String[] @default([])
  prevention   String[] @default([])
  tags         String[] @default([])
  costEstimate Int?     @map("cost_estimate")
  upvotes      Int      @default(0)
  published    Boolean  @default(true) @map("published")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([createdAt])
  @@index([upvotes])
  @@index([published])
  @@map("incidents")
  votes        Vote[]
  favorites    Favorite[]
  comments     Comment[]
}

model DraftIncident {
  id           String       @id @default(cuid())
  slug         String       @unique
  title        String
  context      String       @db.Text
  whatHappened String       @db.Text @map("what_happened")
  rootCause    String       @db.Text @map("root_cause")
  impact       String       @db.Text
  fix          String       @db.Text
  lessons      String[]     @default([])
  prevention   String[]     @default([])
  tags         String[]     @default([])
  costEstimate Int?         @map("cost_estimate")
  status       DraftStatus  @default(DRAFT)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@index([createdAt])
  @@map("draft_incidents")
}

enum DraftStatus {
  DRAFT
  DISAPPROVED
}

model Vote {
  id         String   @id @default(cuid())
  incidentId String
  userId     String
  createdAt  DateTime @default(now()) @map("created_at")

  incident Incident @relation(fields: [incidentId], references: [id])

  @@unique([incidentId, userId])
  @@map("votes")
}

model Favorite {
  id         String   @id @default(cuid())
  incidentId String
  userId     String
  createdAt  DateTime @default(now()) @map("created_at")

  incident Incident @relation(fields: [incidentId], references: [id])

  @@unique([incidentId, userId])
  @@map("favorites")
}

model Comment {
  id         String    @id @default(cuid())
  incidentId String
  parentId   String?   @map("parent_id")
  userId     String?
  authorName String?
  body       String    @db.Text
  createdAt  DateTime  @default(now()) @map("created_at")

  incident Incident @relation(fields: [incidentId], references: [id])
  parent   Comment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies  Comment[] @relation("CommentReplies")

  @@index([incidentId, createdAt])
  @@index([parentId])
  @@map("comments")
}
